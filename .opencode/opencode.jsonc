{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser", "chromium"],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "@modelcontextprotocol/server-postgres", "{env:DATABASE_URL}"],
      "enabled": false
    }
  }
}
